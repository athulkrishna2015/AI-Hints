{
    "ai_provider": "openai",
    "api_keys": {
        "openai": "",
        "anthropic": "",
        "gemini": "",
        "openrouter": "",
        "grok": "",
        "deepseek": "",
        "groq": "",
        "nvidia": "",
        "mistral": "",
        "huggingface": ""
    },
    "local_endpoint": {
        "base_url": "http://localhost:11434/v1",
        "model": "llama3"
    },
    "models": {
        "openai": "gpt-4o-mini",
        "anthropic": "claude-3-haiku-20240307",
        "gemini": "gemini-1.5-flash",
        "openrouter": "meta-llama/llama-3-8b-instruct",
        "grok": "grok-1",
        "deepseek": "deepseek-chat",
        "groq": "llama3-8b-8192",
        "nvidia": "meta/llama3-8b-instruct",
        "mistral": "mistral-small-latest",
        "huggingface": "meta-llama/Meta-Llama-3-8B-Instruct"
    },
    "target_fields": [
        "Extras",
        "Back",
        "Text",
        "Extra"
    ],
    "system_prompt": "You are a helpful assistant that helps students prepare for exams. Based on the provided Anki card Front and Back content, generate both helpful hints AND plausible multiple-choice distractors. Return the result as a JSON object with two keys: 'hints' (array of strings) and 'options' (array of strings). Do not include the correct answer in the options. Format: {\"hints\": [\"hint1\", ...], \"options\": [\"opt1\", ...]}",
    "storage_mode": "html",
    "options_count": 4,
    "show_hints_button": true,
    "show_options_button": true,
    "use_combined_button": false,
    "custom_providers": {},
    "note_type_fields": {
        "Cloze": ["Text"],
        "Basic": ["Front", "Back"]
    }
}
